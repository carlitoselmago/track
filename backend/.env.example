TRACK_SECRET_KEY=change-me-in-production
TRACK_DATABASE_URL=sqlite:///./data/track.db
TRACK_API_PREFIX=/api
TRACK_ACCESS_TOKEN_EXPIRE_MINUTES=15
TRACK_REFRESH_TOKEN_EXPIRE_DAYS=1
TRACK_DEFAULT_BOARD_COLOR=#16A34A
TRACK_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HTTP server
TRACK_SERVER_HOST=127.0.0.1
TRACK_SERVER_PORT=8000
TRACK_SERVER_RELOAD=false
TRACK_SERVER_WORKERS=1

# Admin bootstrap (used on startup)
TRACK_ADMIN_BOOTSTRAP_EMAIL=admin@email.com
TRACK_ADMIN_BOOTSTRAP_PASSWORD=admin123456
TRACK_ADMIN_BOOTSTRAP_FULL_NAME=System Admin
TRACK_ADMIN_RESET_PASSWORD_ON_STARTUP=false

# SMTP (optional)
TRACK_SMTP_HOST=
TRACK_SMTP_PORT=587
TRACK_SMTP_USERNAME=
TRACK_SMTP_PASSWORD=
TRACK_SMTP_USE_TLS=true
TRACK_EMAIL_FROM=noreply@track.local
